<% layout('layout/boilerplate') -%>

<div style="max-width: 600px; margin: 30px auto; font-family: sans-serif;">
    <p>Modify the system parameters for Asset ID: <strong><%= vehicle.id %></strong></p>

    <% if (error) { %>
        <div style="color: #721c24; background-color: #f8d7da; border: 1px solid #f5c6cb; padding: 12px; margin-bottom: 20px; border-radius: 4px;">
            <strong>Update Constraint Error:</strong> <%= error %>
        </div>
    <% } %>

    <form action="/TransitOPS/vehicles/<%= vehicle.id %>" method="POST" style="display: flex; flex-direction: column; gap: 15px;">
        
        <div>
            <label style="display: block; font-weight: bold; margin-bottom: 5px;">Registration / Plate Number (Unique):</label>
            <input type="text" name="registration_number" value="<%= vehicle.registration_number %>" required style="width: 100%; padding: 8px;">
        </div>

        <div style="display: flex; gap: 15px;">
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Model Name:</label>
                <input type="text" name="model_name" value="<%= vehicle.model_name %>" required style="width: 100%; padding: 8px;">
            </div>
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Type:</label>
                <input type="text" name="type" value="<%= vehicle.type %>" required style="width: 100%; padding: 8px;">
            </div>
        </div>

        <div style="display: flex; gap: 15px;">
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Max Load Capacity (kg):</label>
                <input type="number" step="0.01" name="max_load_capacity" value="<%= vehicle.max_load_capacity %>" required style="width: 100%; padding: 8px;">
            </div>
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Current Odometer (km):</label>
                <input type="number" step="0.01" name="odometer" value="<%= vehicle.odometer %>" required style="width: 100%; padding: 8px;">
            </div>
        </div>

        <div style="display: flex; gap: 15px;">
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Acquisition Cost ($):</label>
                <input type="number" step="0.01" name="acquisition_cost" value="<%= vehicle.acquisition_cost %>" required style="width: 100%; padding: 8px;">
            </div>
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Assigned Operational Region:</label>
                <input type="text" name="region" value="<%= vehicle.region || '' %>" placeholder="Unassigned" style="width: 100%; padding: 8px;">
            </div>
        </div>

        <div>
            <label style="display: block; font-weight: bold; margin-bottom: 5px;">Operational Status:</label>
            <select name="status" style="width: 100%; padding: 8px;">
                <option value="Available" <%= vehicle.status === 'Available' ? 'selected' : '' %>>Available</option>
                <option value="On Trip" <%= vehicle.status === 'On Trip' ? 'selected' : '' %>>On Trip</option>
                <option value="In Shop" <%= vehicle.status === 'In Shop' ? 'selected' : '' %>>In Shop</option>
                <option value="Retired" <%= vehicle.status === 'Retired' ? 'selected' : '' %>>Retired</option>
            </select>
        </div>

        <div style="margin-top: 15px;">
            <button type="submit" style="background-color: #007bff; color: white; padding: 10px 20px; border: none; cursor: pointer; border-radius: 4px; font-weight: bold;">
                Apply Modifications
            </button>
            <a href="/vehicles" style="margin-left: 15px; color: #555; text-decoration: none;">Cancel</a>
        </div>
    </form>
</div>
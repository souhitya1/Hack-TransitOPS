<% layout('layout/boilerplate') -%>

<div style="padding: 20px; font-family: sans-serif;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h1>Trip Routing Matrix</h1>
        <a href="/TransitOPS/trips/new" style="background-color: #107c41; color: white; padding: 10px 15px; text-decoration: none; border-radius: 4px; font-weight: bold;">
            + Deploy New Trip
        </a>
    </div>

    <table border="1" cellpadding="10" style="border-collapse: collapse; width: 100%; text-align: left; border-color: #ddd;">
        <thead style="background-color: #f2f2f2;">
            <tr>
                <th>Trip ID</th>
                <th>Route Strategy</th>
                <th>Cargo / Distance</th>
                <th>Assigned Assets</th>
                <th>Stage Status</th>
                <th>Operational Lifecycle Controls</th>
            </tr>
        </thead>
        <tbody>
            <% if (trips.length === 0) { %>
                <tr>
                    <td colspan="6" style="text-align: center; color: #777;">No logistical trip records running.</td>
                </tr>
            <% } %>
            <% for(let trip of trips) { %>
                <tr>
                    <td><strong>#<%= trip.id %></strong></td>
                    <td><%= trip.source %> ➡️ <%= trip.destination %></td>
                    <td><%= trip.cargo_weight %> kg / <%= trip.planned_distance || 'N/A' %> km</td>
                    <td>
                        🚛 Vehicle: <strong><%= trip.registration_number %></strong><br>
                        🪪 Operator: <strong><%= trip.driver_name %></strong>
                    </td>
                    <td>
                        <span style="padding: 4px 8px; border-radius: 4px; font-size: 0.85em; font-weight: bold;
                            background-color: <%= trip.status === 'Draft' ? '#dfdfdf' : trip.status === 'Dispatched' ? '#cee4ff' : trip.status === 'Completed' ? '#d4edda' : '#f8d7da' %>;
                            color: <%= trip.status === 'Draft' ? '#333' : trip.status === 'Dispatched' ? '#004085' : trip.status === 'Completed' ? '#155724' : '#721c24' %>;">
                            <%= trip.status %>
                        </span>
                    </td>
                    <td>
                        <% if(trip.status === 'Draft') { %>
                            <div style="display: flex; gap: 8px;">
                                <form action="/TransitOPS/trips/<%= trip.id %>/status" method="POST" style="margin:0;">
                                    <input type="hidden" name="action" value="DISPATCH">
                                    <button type="submit" style="background-color: #007bff; color: white; border: none; padding: 6px 12px; cursor: pointer; border-radius: 4px; font-weight: bold;">Dispatch</button>
                                </form>
                                <form action="/TransitOPS/trips/<%= trip.id %>/status" method="POST" style="margin:0;">
                                    <input type="hidden" name="action" value="CANCEL">
                                    <button type="submit" style="background-color: #dc3545; color: white; border: none; padding: 6px 12px; cursor: pointer; border-radius: 4px;">Cancel</button>
                                </form>
                            </div>
                        <% } %>

                        <% if(trip.status === 'Dispatched') { %>
                            <form action="/TransitOPS/trips/<%= trip.id %>/status" method="POST" style="background: #fafafa; border: 1px solid #ccc; padding: 10px; border-radius: 4px; max-width: 220px;">
                                <input type="hidden" name="action" value="COMPLETE">
                                <div style="margin-bottom: 8px;">
                                    <label style="font-size: 0.8rem; font-weight: bold; display: block; margin-bottom: 2px;">Final Odometer:</label>
                                    <input type="number" step="0.01" name="final_odometer" placeholder="Odometer (km)" required style="padding: 4px; font-size: 0.85em; width: 100%; box-sizing: border-box;">
                                </div>
                                <div style="margin-bottom: 8px;">
                                    <label style="font-size: 0.8rem; font-weight: bold; display: block; margin-bottom: 2px;">Fuel Consumed:</label>
                                    <input type="number" step="0.01" name="fuel_consumed" placeholder="Fuel (Liters)" required style="padding: 4px; font-size: 0.85em; width: 100%; box-sizing: border-box;">
                                </div>
                                <button type="submit" style="background-color: #28a745; color: white; border: none; padding: 6px 10px; cursor: pointer; border-radius: 4px; font-weight: bold; width: 100%;">Complete Trip</button>
                            </form>
                        <% } %>

                        <% if(trip.status === 'Completed' || trip.status === 'Cancelled') { %>
                            <span style="color: #777; font-size: 0.9em; font-style: italic;">Locked Archive</span>
                        <% } %>
                    </td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>
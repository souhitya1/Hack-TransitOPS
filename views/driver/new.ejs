<% layout('layout/boilerplate') -%>

<div style="max-width: 600px; margin: 30px auto; font-family: sans-serif;">
    <p>Register legal credentials and profiles for logistics operators.</p>

    <% if (error) { %>
        <div style="color: #721c24; background-color: #f8d7da; border: 1px solid #f5c6cb; padding: 12px; margin-bottom: 20px; border-radius: 4px;">
            <strong>Credential Error:</strong> <%= error %>
        </div>
    <% } %>

    <form action="/TransitOPS/drivers" method="POST" style="display: flex; flex-direction: column; gap: 15px;">
        
        <div>
            <label style="display: block; font-weight: bold; margin-bottom: 5px;">Full Name:</label>
            <input type="text" name="name" placeholder="John Doe" required style="width: 100%; padding: 8px;">
        </div>

        <div style="display: flex; gap: 15px;">
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">License Number (Unique):</label>
                <input type="text" name="license_number" placeholder="e.g., DL-9876543" required style="width: 100%; padding: 8px;">
            </div>
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">License Category:</label>
                <input type="text" name="license_category" placeholder="e.g., Class A CDL" style="width: 100%; padding: 8px;">
            </div>
        </div>

        <div style="display: flex; gap: 15px;">
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">License Expiry Date:</label>
                <input type="date" name="license_expiry_date" required style="width: 100%; padding: 8px;">
            </div>
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Contact Number:</label>
                <input type="text" name="contact_number" placeholder="e.g., +15551234" style="width: 100%; padding: 8px;">
            </div>
        </div>

        <div style="display: flex; gap: 15px;">
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Initial Safety Score (%):</label>
                <input type="number" step="0.01" min="0" max="100" name="safety_score" value="100.00" style="width: 100%; padding: 8px;">
            </div>
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Status:</label>
                <select name="status" style="width: 100%; padding: 8px;">
                    <option value="Available">Available</option>
                    <option value="On Trip">On Trip</option>
                    <option value="Off Duty">Off Duty</option>
                    <option value="Suspended">Suspended</option>
                </select>
            </div>
        </div>

        <div style="margin-top: 15px;">
            <button type="submit" style="background-color: #2b579a; color: white; padding: 10px 20px; border: none; cursor: pointer; border-radius: 4px; font-weight: bold;">
                Save Driver Profile
            </button>
            <a href="/TransitOPS/drivers" style="margin-left: 15px; color: #555; text-decoration: none;">Cancel</a>
        </div>
    </form>
</div>